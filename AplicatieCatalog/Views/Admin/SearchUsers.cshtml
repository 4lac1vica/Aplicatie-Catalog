@model List<AplicatieCatalog.ViewModels.ApplicationUserViewModel>

@{
    ViewData["Title"] = "Search Users";
}

<h2>Cauta utilizatori</h2>

<form method="get" asp-action="SearchUsers">
    <div class="mb-3">
        <label class="form-label">Email utilizator</label>
        <input type="text" name="term" value="@ViewBag.Term" class="form-control" placeholder="ex: test@mail.com" />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped mt-4">
        <thead>
            <tr>
                <th>Email</th>
                <th>Actiune</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        <form asp-action="DeleteUser" method="post">
                            <input type="hidden" name="userId" value="@user.Id" />

                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Esti sigur ca vrei sa stergi acest utilizator?');">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else if (ViewBag.Term != null)
{
    <p class="mt-3 text-danger">Nu s-au gasit utilizatori.</p>
}