@model AplicatieCatalog.ViewModels.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-5">
    <div class="card shadow-sm w-50 mx-auto">
        <div class="card-body">
            <h2 class="text-center mb-4">Edit Profile</h2>

            <form asp-controller="Account" asp-action="EditProfile" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">First Name</label>
                    <input value="@Model.FirstName" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Last Name</label>
                    <input value="@Model.LastName" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="Telephone"></label>
                    <input asp-for="Telephone" class="form-control" />
                    <span asp-validation-for="Telephone" class="text-danger"></span>
                </div>

                @if (Model.Role == "Student")
                {
                    <div class="mb-3">
                        <label asp-for="Grupa"></label>
                        <input asp-for="Grupa" class="form-control" />
                        <span asp-validation-for="Grupa" class="text-danger"></span>
                    </div>
                }

                @if (Model.Role == "Teacher")
                {
                    <div class="mb-3">
                        <label asp-for="Materie"></label>
                        <input asp-for="Materie" class="form-control" />
                        <span asp-validation-for="Materie" class="text-danger"></span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Save Changes
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}