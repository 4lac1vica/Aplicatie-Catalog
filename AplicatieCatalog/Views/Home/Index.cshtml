@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">

    <h1 class="display-4">Bine ai venit în cataLOG</h1>
    <p>Aplicatia ta pentru gestionarea catalogului.</p>

    <h2 class="mb-4">Select the role you want to log in as:</h2>

    <div class="mt-4">

        <a class="btn btn-success btn-lg m-2"
           asp-controller="Account"
           asp-action="Login"
           asp-route-role="Student">
            Student
        </a>

        <a class="btn btn-primary btn-lg m-2"
           asp-controller="Account"
           asp-action="Login"
           asp-route-role="Teacher">
            Teacher
        </a>

        <a class="btn btn-dark btn-lg m-2"
           asp-controller="Account"
           asp-action="Login"
           asp-route-role="Admin">
            Admin
        </a>

    </div>

    <h3 class="mt-5">Don't have an account? Sign in!</h3>

    <div class="mt-3">
        <a class="btn btn-outline-success btn-lg"
           asp-controller="Account"
           asp-action="Register">
            Sign In
        </a>
    </div>

    <h4 class="mt-5">Continue anonymously</h4>
    <p class="mb-4">Note: If you continue anonymously you have functional restrictions.</p>

    <div>
        <a class="btn btn-outline-dark btn-lg">
            Continue Unregistered
        </a>
    </div>

</div>